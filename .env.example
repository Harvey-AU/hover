# Production Environment Configuration
# (For development, just run `air` - no manual setup required)

# App
APP_ENV=production
APP_URL=https://hover.app.goodnative.co
PORT=8080
SETTINGS_URL=https://hover.app.goodnative.co/settings

# Production Database (Supabase)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
# Local fallback when DATABASE_URL is not set
POSTGRES_DB=hover

# Supabase Auth (Production)
SUPABASE_AUTH_URL=https://your-project.supabase.co
# Optional migration fallback auth URL for issuer/JWKS validation
SUPABASE_FALLBACK_AUTH_URL=https://your-legacy-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_production_publishable_key

# Paddle
PADDLE_VENDOR_ID=your_vendor_id
PADDLE_API_KEY=your_api_key
PADDLE_PUBLIC_KEY=your_public_key

# Fly.io
FLY_API_TOKEN=your_fly_token

# Worker Pool Scaling
GNH_WORKER_IDLE_THRESHOLD=10          # Mark worker idle after 10 consecutive no-task responses (0 = disabled)
GNH_WORKER_SCALE_COOLDOWN_SECONDS=15  # Minimum time between scale-down operations
GNH_HEALTH_PROBE_INTERVAL_SECONDS=30  # Health probe interval when all workers idle (0 = disabled)

# Development
DEBUG=true                  # Enable debug logging
LOG_LEVEL=debug            # debug, info, warn, or error
RUN_INTEGRATION_TESTS=true # Enable integration tests

# Webflow
WEBFLOW_CLIENT_ID=your_client_id_here
WEBFLOW_CLIENT_SECRET=your_client_secret_here
WEBFLOW_REDIRECT_URI=                       # optional override for Webflow OAuth callback URL

# Google Analytics
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
