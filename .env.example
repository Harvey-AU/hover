# Environment Configuration
#
# Local development: run ./dev.sh — it auto-generates .env.local from
# supabase status. You rarely need to create env files manually.
#
# Production / staging: non-secret config lives in fly.toml [env].
# Secrets are injected via 1Password (see docs/operations/ENV_VARS.md).

# ── App ────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://hover.app.goodnative.co
PORT=8080
SETTINGS_URL=https://hover.app.goodnative.co/settings

# ── Database ───────────────────────────────────────────────────────
# Production uses DATABASE_URL from 1Password → Fly secrets.
# Local dev defaults to Supabase local (localhost:54322/postgres)
# when DATABASE_URL is unset and APP_ENV=development.
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# ── Supabase Auth ──────────────────────────────────────────────────
SUPABASE_AUTH_URL=https://your-project.supabase.co
SUPABASE_FALLBACK_AUTH_URL=https://your-legacy-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_production_publishable_key

# ── OAuth Client IDs (non-secret, also in fly.toml) ───────────────
SLACK_CLIENT_ID=your_slack_client_id
WEBFLOW_CLIENT_ID=your_webflow_client_id
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── OAuth Client Secrets (1Password → Fly secrets) ────────────────
SLACK_CLIENT_SECRET=your_slack_client_secret
WEBFLOW_CLIENT_SECRET=your_webflow_client_secret
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Observability ──────────────────────────────────────────────────
SENTRY_DSN=your_sentry_dsn
OTEL_EXPORTER_OTLP_HEADERS=your_otlp_auth_header

# ── Worker Pool Scaling ────────────────────────────────────────────
GNH_WORKER_IDLE_THRESHOLD=10
GNH_WORKER_SCALE_COOLDOWN_SECONDS=15
GNH_HEALTH_PROBE_INTERVAL_SECONDS=30

# ── Development Overrides ──────────────────────────────────────────
# These are typically set in .env.local (auto-generated by dev.sh)
# DEBUG=true
# LOG_LEVEL=debug
